# Пример файла конфигурации для базовой миграции
# Скопируйте этот файл как .env и заполните значениями

# ============================================
# НАСТРОЙКИ SOURCECRAFT
# ============================================

# Организация на SourceCraft
# Пример: если URL репозитория https://sourcecraft.dev/my-org/my-repo
# то SOURCE_CRAFT_ORG="my-org"
SOURCE_CRAFT_ORG="ваша_организация"

# Имя репозитория на SourceCraft
# Пример: если URL репозитория https://sourcecraft.dev/my-org/my-repo
# то SOURCE_CRAFT_REPO="my-repo"
SOURCE_CRAFT_REPO="ваш_репозиторий"

# Токен доступа к SourceCraft (опционально)
# Если не указан, будет запрошен при клонировании
# Получить токен: Настройки -> Безопасность -> Персональные токены
SOURCE_CRAFT_TOKEN="ваш_sourcecraft_токен"

# ============================================
# НАСТРОЙКИ GITHUB
# ============================================

# Имя пользователя на GitHub
GITHUB_USERNAME="ваш_github_username"

# Имя репозитория на GitHub
# Рекомендуется использовать то же имя, что и на SourceCraft
GITHUB_REPO="ваш_репозиторий"

# Токен доступа к GitHub (опционально)
# Если не указан, будет запрошен при отправке
# Получить токен: Settings -> Developer settings -> Personal access tokens
# Права: repo (полный контроль репозиториев)
GITHUB_TOKEN="ваш_github_токен"

# ============================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# ============================================

# Ветка по умолчанию (обычно main или master)
DEFAULT_BRANCH="main"

# Временная директория для mirror-клона
# Будет создана автоматически с timestamp
# TEMP_DIR="temp-mirror-$(date +%s)"

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# Сохранять временные файлы после миграции? (true/false)
KEEP_TEMP_FILES=false

# Проверять миграцию после завершения? (true/false)
VERIFY_AFTER_MIGRATION=true

# ============================================
# ПРИМЕРЫ ДЛЯ ТЕСТИРОВАНИЯ
# ============================================

# Пример 1: Тестовый репозиторий
# SOURCE_CRAFT_ORG="test-org"
# SOURCE_CRAFT_REPO="test-repo"
# GITHUB_USERNAME="test-user"
# GITHUB_REPO="test-repo"

# Пример 2: Продакшн репозиторий
# SOURCE_CRAFT_ORG="company"
# SOURCE_CRAFT_REPO="web-app"
# GITHUB_USERNAME="company-dev"
# GITHUB_REPO="web-app"

# ============================================
# ВАЖНЫЕ ПРИМЕЧАНИЯ
# ============================================

# 1. Никогда не коммитьте этот файл с реальными токенами в Git!
# 2. Добавьте .env в .gitignore
# 3. Используйте .env.example как шаблон
# 4. Храните токены в безопасном месте
# 5. Регулярно обновляйте токены (срок действия обычно 30-90 дней)

# ============================================
# АВТОМАТИЧЕСКАЯ ГЕНЕРАЦИЯ
# ============================================

# Для автоматической генерации .env файла:
# cp .env.example .env
# nano .env  # или любой текстовый редактор

# Для быстрого заполнения (осторожно, токены в истории команд!):
# echo "SOURCE_CRAFT_ORG=\"my-org\"" > .env
# echo "SOURCE_CRAFT_REPO=\"my-repo\"" >> .env
# echo "GITHUB_USERNAME=\"my-user\"" >> .env
# echo "GITHUB_REPO=\"my-repo\"" >> .env